# agent-expertise-api local client configuration (ADR-0028).
#
# This is the committed EXAMPLE. Copy it to `.env.local` (gitignored) and put
# your real values there. The extension reads ONLY `.env.local` from this
# directory plus `process.env`; it never discovers arbitrary repo `.env` files.
# Precedence: process.env > .env.local > built-in defaults.

# Loopback origin of the local agent-expertise-api. Must be loopback
# (localhost / 127.0.0.0/8 / ::1); non-loopback URLs are refused in phase 1.
PI_EXPERTISE_API_BASE_URL=http://127.0.0.1:8080

# Required for ALL calls. Never commit a real key.
PI_EXPERTISE_API_KEY=replace-me

# Required ONLY for write/create operations (the expertise_create tool, #318).
# Read/search calls ignore this value. Set to 1 to enable local writes.
PI_EXPERTISE_ALLOW_LOCALDEV_WRITE=0
